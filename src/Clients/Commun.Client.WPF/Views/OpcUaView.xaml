<UserControl x:Class="Commun.Client.WPF.Views.OpcUaView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{DynamicResource MetroWindowBackgroundBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <GroupBox Header="连接" Grid.Row="0" Style="{DynamicResource MetroGroupBox}">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label Content="端点:" Style="{DynamicResource MetroLabel}"/>
                <TextBox x:Name="TxtEndpoint" Text="opc.tcp://localhost:4840" Width="250" Style="{DynamicResource MetroTextBox}"/>
                <Button x:Name="BtnConnect" Content="连接" Style="{DynamicResource MetroButton}" Margin="10,0,0,0"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Header="读写" Grid.Row="1" Style="{DynamicResource MetroGroupBox}">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label Content="节点:" Style="{DynamicResource MetroLabel}"/>
                <TextBox x:Name="TxtNodeId" Text="ns=2;s=Demo" Width="200" Style="{DynamicResource MetroTextBox}"/>
                <Label Content="值:" Style="{DynamicResource MetroLabel}" Margin="10,0,0,0"/>
                <TextBox x:Name="TxtValue" Width="80" Style="{DynamicResource MetroTextBox}"/>
                <Button x:Name="BtnRead" Content="读取" Style="{DynamicResource MetroButton}" Margin="10,0,0,0"/>
                <Button x:Name="BtnWrite" Content="写入" Style="{DynamicResource MetroButton}" Margin="5,0,0,0"/>
            </StackPanel>
        </GroupBox>
        <TextBox x:Name="TxtLog" Grid.Row="2" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#FF1E1E1E" Foreground="#FF00FF00" FontFamily="Consolas"/>
    </Grid>
</UserControl>
