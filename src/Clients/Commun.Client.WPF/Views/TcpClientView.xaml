<UserControl x:Class="Commun.Client.WPF.Views.TcpClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Commun.Client.WPF.Controls"
             Background="{DynamicResource MetroWindowBackgroundBrush}">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Connection -->
        <GroupBox Header="连接" Grid.Row="0" Style="{DynamicResource MetroGroupBox}">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label Content="主机:" Style="{DynamicResource MetroLabel}" VerticalAlignment="Center" />
                <TextBox x:Name="TxtHost" Text="127.0.0.1" Width="150" Style="{DynamicResource MetroTextBox}" />
                <Label Content="端口:" Style="{DynamicResource MetroLabel}" VerticalAlignment="Center" Margin="10,0,0,0" />
                <TextBox x:Name="TxtPort" Text="502" Width="60" Style="{DynamicResource MetroTextBox}" />
                <Button x:Name="BtnConnect" Content="连接" Style="{DynamicResource MetroButton}" Margin="10,0,0,0" Click="BtnConnect_Click" />
                <Button x:Name="BtnDisconnect" Content="断开" Style="{DynamicResource MetroButton}" Margin="5,0,0,0" IsEnabled="False" Click="BtnDisconnect_Click" />
            </StackPanel>
        </GroupBox>

        <!-- Send -->
        <GroupBox Header="发送" Grid.Row="1" Style="{DynamicResource MetroGroupBox}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSend" Grid.Column="0" Height="60" Style="{DynamicResource MetroTextBox}" AcceptsReturn="True" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <Button x:Name="BtnSend" Content="发送" Style="{DynamicResource MetroButton}" IsEnabled="False" Click="BtnSend_Click" />
                    <CheckBox x:Name="ChkHex" Content="HEX" Style="{DynamicResource MetroCheckBox}" Margin="0,5,0,0" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Options -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,5">
            <CheckBox x:Name="ChkHexRecv" Content="HEX 接收" Style="{DynamicResource MetroCheckBox}" />
        </StackPanel>

        <!-- Log -->
        <TextBox x:Name="TxtLog" Grid.Row="3" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                 Background="#FF1E1E1E" Foreground="#FF00FF00" FontFamily="Consolas" FontSize="12"
                 TextWrapping="Wrap" />
    </Grid>
</UserControl>
